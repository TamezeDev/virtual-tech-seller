<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="800.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.zeki.virtualtechseller.controller.scene.admin.AddProductViewController">
   <center>
      <VBox alignment="TOP_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="400.0" prefWidth="800.0" spacing="40.0" styleClass="panel-a">
         <children>
            <VBox alignment="CENTER" spacing="20.0">
               <children>
                  <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="20.0">
                     <children>
                        <TextField fx:id="productNameTxt" alignment="CENTER" maxWidth="-Infinity" prefHeight="40.0" prefWidth="300.0" promptText="Nombre del producto" styleClass="text-field" />
                        <TextField fx:id="descriptTxt" alignment="CENTER" maxWidth="-Infinity" prefWidth="300.0" promptText="Descripción" styleClass="text-field" />
                     </children>
                  </HBox>
                  <HBox alignment="CENTER" spacing="60.0">
                     <children>
                        <VBox alignment="CENTER">
                           <children>
                              <Label styleClass="label-m" text="Tipo de producto">
                                 <padding>
                                    <Insets bottom="20.0" />
                                 </padding>
                              </Label>
                              <HBox alignment="CENTER" prefHeight="100.0" spacing="20.0">
                                 <children>
                                    <RadioButton fx:id="newProductRb" mnemonicParsing="false" styleClass="availability-radio" text="Nuevo" />
                                    <RadioButton fx:id="usedProductRb" mnemonicParsing="false" styleClass="availability-radio" text="Usado" />
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                     </children>
                  </HBox>
                  <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="40.0">
                     <children>
                        <TextField fx:id="stockTxt" alignment="CENTER" maxWidth="-Infinity" prefHeight="31.0" prefWidth="132.0" promptText="Stock" styleClass="text-field" />
                        <TextField fx:id="basePriceTxt" alignment="CENTER" maxWidth="-Infinity" prefWidth="150.0" promptText="Precio_base" styleClass="text-field" />
                        <ComboBox fx:id="categoryCb" promptText="Categorias" styleClass="model-ComboBoxA" />
                     </children>
                  </HBox>
                  <ImageView fx:id="productImg" fitHeight="100.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="true" />
                  <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0" spacing="20.0">
                     <children>
                        <Label fx:id="feedbackLabel" alignment="CENTER" styleClass="label-b" text="Este será el texto de feedback" />
                        <HBox alignment="CENTER" fillHeight="false" prefHeight="100.0" prefWidth="200.0" spacing="50.0">
                           <children>
                              <Button fx:id="gobackBtn" mnemonicParsing="false" styleClass="button-a" text=" Regresar">
                                 <graphic>
                                    <ImageView fitHeight="23.0" fitWidth="28.0" pickOnBounds="true" preserveRatio="true">
                                       <image>
                                          <Image url="@../../img/system/goback.png" />
                                       </image>
                                    </ImageView>
                                 </graphic>
                              </Button>
                              <Button fx:id="addProductBtn" mnemonicParsing="false" styleClass="button-a" text="Añadir producto" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </children>
               <padding>
                  <Insets bottom="30.0" left="20.0" right="20.0" top="30.0" />
               </padding>
            </VBox>
         </children>
         <padding>
            <Insets bottom="20.0" left="50.0" right="50.0" top="20.0" />
         </padding>
      </VBox>
   </center>
   <bottom>
      <HBox alignment="CENTER_RIGHT" spacing="5.0" BorderPane.alignment="CENTER_RIGHT">
         <children>
            <Label styleClass="label-a" text="Desarrollado por Ezequiel Tamayo - Versión: 1.0.0" />
         </children>
         <BorderPane.margin>
            <Insets bottom="15.0" right="50.0" />
         </BorderPane.margin>
      </HBox>
   </bottom>
   <top>
      <ImageView fitHeight="170.0" fitWidth="350.0" pickOnBounds="true" BorderPane.alignment="CENTER">
         <image>
            <Image url="@../../img/system/logo.png" />
         </image>
         <BorderPane.margin>
            <Insets top="40.0" />
         </BorderPane.margin>
      </ImageView>
   </top>
   <stylesheets>
      <URL value="@../../css/global_styles.css" />
      <URL value="@../../css/checkbox.css" />
      <URL value="@../../css/comboBox.css" />
      <URL value="@../../css/radiobutton.css" />
   </stylesheets>
</BorderPane>
