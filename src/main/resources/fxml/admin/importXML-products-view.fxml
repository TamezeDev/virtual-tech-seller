<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="800.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.zeki.virtualtechseller.controller.admin.ImportProductController">
   <center>
      <VBox alignment="TOP_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="500.0" prefWidth="986.0" spacing="40.0" styleClass="panel-a">
         <children>
            <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="60.0">
               <children>
                  <Button fx:id="gobackBtn" mnemonicParsing="false" prefHeight="43.0" prefWidth="188.0" styleClass="button-a" text=" Regresar">
                     <graphic>
                        <ImageView fitHeight="21.0" fitWidth="29.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../../img/system/goback.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
                  <Button fx:id="importXmlBtn" mnemonicParsing="false" prefHeight="43.0" prefWidth="191.0" styleClass="button-a" text="Importar XML" />
                  <Button fx:id="exportXmlBtn" layoutX="616.0" layoutY="10.0" mnemonicParsing="false" prefHeight="43.0" prefWidth="188.0" styleClass="button-a" text="Exportar XML" />
                  <Button fx:id="saveOnDbBtn" mnemonicParsing="false" styleClass="button-a" text="Guardar en servidor" />
               </children>
               <VBox.margin>
                  <Insets />
               </VBox.margin>
            </HBox>
            <HBox prefHeight="100.0" prefWidth="200.0" />
            <TableView fx:id="itemsTable" styleClass="personalTable">
               <columns>
                  <TableColumn fx:id="nameColumn" prefWidth="75.0" text="Producto" />
                  <TableColumn fx:id="descriptionColumn" prefWidth="75.0" text="Descripción" />
                  <TableColumn fx:id="categoryColumn" prefWidth="75.0" text="Categoría" />
                  <TableColumn fx:id="stockColumn" prefWidth="75.0" text="Stock" />
                  <TableColumn fx:id="priceColumn" prefWidth="75.0" text="Precio base" />
                  <TableColumn fx:id="typeColumn" prefWidth="75.0" text="Estado" />
               </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
            <Label fx:id="feedbackLabel" alignment="CENTER" styleClass="label-b" text="Este será el texto de feedback" visible="false" />
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </VBox>
   </center>
   <bottom>
      <HBox alignment="CENTER_RIGHT" spacing="5.0" BorderPane.alignment="CENTER_RIGHT">
         <children>
            <Label styleClass="label-a" text="Desarrollado por Ezequiel Tamayo - Versión: 1.0.0" />
         </children>
         <BorderPane.margin>
            <Insets bottom="15.0" right="50.0" />
         </BorderPane.margin>
      </HBox>
   </bottom>
   <top>
      <ImageView fitHeight="170.0" fitWidth="350.0" pickOnBounds="true" BorderPane.alignment="CENTER">
         <image>
            <Image url="@../../img/system/logo.png" />
         </image>
         <BorderPane.margin>
            <Insets top="30.0" />
         </BorderPane.margin>
      </ImageView>
   </top>
   <stylesheets>
      <URL value="@../../css/global_styles.css" />
      <URL value="@../../css/tables.css" />
      <URL value="@../../css/comboBox.css" />
   </stylesheets>
</BorderPane>
