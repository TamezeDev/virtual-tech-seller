<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="800.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.zeki.virtualtechseller.controller.moderator.VisitControlController">
   <center>
      <VBox alignment="TOP_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="529.0" prefWidth="1035.0" spacing="40.0" styleClass="panel-a">
         <children>
            <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="100.0">
               <children>
                  <Button fx:id="gobackBtn" mnemonicParsing="false" styleClass="button-a" text=" Regresar">
                     <graphic>
                        <ImageView fitHeight="21.0" fitWidth="29.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../../img/system/goback.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
                  <ComboBox fx:id="filterVisitsCb" promptText="FIltros" styleClass="model-ComboBoxA" />
                  <ComboBox fx:id="eventsCb" layoutX="449.0" layoutY="16.0" promptText="Eventos" styleClass="model-ComboBoxA" visible="false" />
                  <HBox fx:id="quantityBox" alignment="CENTER" spacing="10.0" visible="false">
                     <children>
                        <Label styleClass="label-a" text="Cantidad total:" />
                        <Label fx:id="totalQuantityLabel" layoutX="10.0" layoutY="10.0" styleClass="label-a" text="X" />
                     </children>
                  </HBox>
               </children>
            </HBox>
            <HBox fx:id="visitFilterBox" alignment="CENTER" fillHeight="false" prefHeight="100.0" prefWidth="200.0" spacing="50.0" visible="false">
               <children>
                  <Label styleClass="label-a" text="Filtrado por visitas:" />
                  <TextField fx:id="minVisitsTxt" alignment="CENTER" maxWidth="-Infinity" prefHeight="31.0" prefWidth="107.0" promptText="Mínimo" styleClass="text-field" />
                  <TextField fx:id="maxVisitsTxt" alignment="CENTER" layoutX="357.0" layoutY="10.0" maxWidth="-Infinity" prefHeight="31.0" prefWidth="98.0" promptText="Máximo" styleClass="text-field" />
                  <Button fx:id="showFilteredBtn" mnemonicParsing="false" styleClass="button-a" text="Filtrar" />
               </children>
            </HBox>
            <Label fx:id="feedbackLabel" alignment="CENTER" styleClass="label-b" text="Este será el texto de feedback" visible="false" />
            <TableView fx:id="visitsTable" prefHeight="351.0" prefWidth="993.0" styleClass="personalTable">
               <columns>
                  <TableColumn fx:id="eventNameColumn" prefWidth="75.0" text="Nombre Evento" />
                  <TableColumn fx:id="quantityColumn" prefWidth="75.0" text="Nº accesos" />
                  <TableColumn fx:id="lastAccessColumn" prefWidth="75.0" text="Ultimo acceso" />
                  <TableColumn fx:id="userNameColumn" prefWidth="75.0" text="Nombre" />
                  <TableColumn fx:id="userLastNameColumn" prefWidth="75.0" text="Apellidos" />
               </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </VBox>
   </center>
   <bottom>
      <HBox alignment="CENTER_RIGHT" spacing="5.0" BorderPane.alignment="CENTER_RIGHT">
         <children>
            <Label styleClass="label-a" text="Desarrollado por Ezequiel Tamayo - Versión: 1.0.0" />
         </children>
         <BorderPane.margin>
            <Insets bottom="15.0" right="50.0" />
         </BorderPane.margin>
      </HBox>
   </bottom>
   <top>
      <ImageView fitHeight="170.0" fitWidth="350.0" pickOnBounds="true" BorderPane.alignment="CENTER">
         <image>
            <Image url="@../../img/system/logo.png" />
         </image>
         <BorderPane.margin>
            <Insets top="30.0" />
         </BorderPane.margin>
      </ImageView>
   </top>
   <stylesheets>
      <URL value="@../../css/global_styles.css" />
      <URL value="@../../css/tables.css" />
      <URL value="@../../css/comboBox.css" />
   </stylesheets>
</BorderPane>
