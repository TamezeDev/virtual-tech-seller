<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="800.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.zeki.virtualtechseller.controller.moderator.SalesControlController">
   <center>
      <VBox alignment="TOP_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="559.0" prefWidth="1143.0" spacing="40.0" styleClass="panel-a">
         <children>
            <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="100.0">
               <children>
                  <Button fx:id="gobackBtn" mnemonicParsing="false" styleClass="button-a" text=" Regresar">
                     <graphic>
                        <ImageView fitHeight="21.0" fitWidth="29.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../../img/system/goback.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
                  <ComboBox fx:id="filterSalesCb" promptText="FIltros" styleClass="model-ComboBoxA" />
                  <ComboBox fx:id="eventsCb" layoutX="449.0" layoutY="16.0" promptText="Eventos" styleClass="model-ComboBoxA" visible="false" />
                  <HBox fx:id="quantityBox" alignment="CENTER" spacing="10.0" visible="false">
                     <children>
                        <Label styleClass="label-a" text="Ganancias totales:" />
                        <Label fx:id="totalQuantityLabel" layoutX="10.0" layoutY="10.0" styleClass="label-a" text="X" />
                     </children>
                  </HBox>
               </children>
            </HBox>
            <HBox fx:id="dateFilterBox" alignment="CENTER" fillHeight="false" prefHeight="100.0" prefWidth="200.0" spacing="50.0" visible="false">
               <children>
                   <Label layoutX="221.0" layoutY="22.0" styleClass="label-a" text="Filtrado entre importes:" />
                   <DatePicker fx:id="initDatePk" prefHeight="31.0" prefWidth="160.0" promptText="Fecha inicio" />
                  <DatePicker fx:id="endDatePk" layoutX="488.0" layoutY="16.0" prefHeight="31.0" prefWidth="150.0" promptText="Fecha fin" />
                  <Button fx:id="showFilteredBtn" mnemonicParsing="false" styleClass="button-a" text="Filtrar" />
               </children>
            </HBox>
            <Label fx:id="feedbackLabel" alignment="CENTER" styleClass="label-b" text="Este será el texto de feedback" visible="false" />
            <TableView fx:id="salesTable" prefHeight="388.0" prefWidth="1101.0" styleClass="personalTable">
               <columns>
                  <TableColumn fx:id="userColumn" prefWidth="75.0" text="Cliente" />
                  <TableColumn fx:id="productColumn" prefWidth="75.0" text="Producto" />
                  <TableColumn fx:id="quantityColumn" prefWidth="75.0" text="Cantidad" />
                  <TableColumn fx:id="priceColumn" prefWidth="75.0" text="Importe total" />
                  <TableColumn fx:id="saleDateColumn" prefWidth="75.0" text="Fecha venta" />
                  <TableColumn fx:id="eventColumn" prefWidth="75.0" text="Evento" />
               </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </VBox>
   </center>
   <bottom>
      <HBox alignment="CENTER_RIGHT" spacing="5.0" BorderPane.alignment="CENTER_RIGHT">
         <children>
            <Label styleClass="label-a" text="Desarrollado por Ezequiel Tamayo - Versión: 1.0.0" />
         </children>
         <BorderPane.margin>
            <Insets bottom="15.0" right="50.0" />
         </BorderPane.margin>
      </HBox>
   </bottom>
   <top>
      <ImageView fitHeight="170.0" fitWidth="350.0" pickOnBounds="true" BorderPane.alignment="CENTER">
         <image>
            <Image url="@../../img/system/logo.png" />
         </image>
         <BorderPane.margin>
            <Insets top="15.0" />
         </BorderPane.margin>
      </ImageView>
   </top>
   <stylesheets>
      <URL value="@../../css/global_styles.css" />
      <URL value="@../../css/tables.css" />
      <URL value="@../../css/comboBox.css" />
   </stylesheets>
</BorderPane>
